# Copy this file to .env.local and fill in values for local development

# Figma personal access token
# Generate at: figma.com → Account Settings → Personal access tokens
FIGMA_TOKEN=

# The ID from your Figma file URL:
# figma.com/design/THIS_PART/file-name
FIGMA_FILE_KEY=

# Slack incoming webhook URL
# Generate at: api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=
